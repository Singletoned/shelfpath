# Local development: use file until Supabase schema/import is ready, then switch to supabase.
SHELFPATH_STORAGE=supabase
SHELFPATH_DEBUG=true
SHELFPATH_SESSION_SECRET=change-me-to-a-random-secret

SUPABASE_URL=https://pkrxfruhnjsifclnhjyc.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_me

# Required only for allow-listed AI-assisted series suggestions.
# OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Only set this locally when running `just catalogue-import`, `just covers-fetch`,
# or local test auth. Do not commit it and do not send it through chat unless
# explicitly required.
# SUPABASE_SERVICE_ROLE_KEY=

# Optional local/debug-only login bypass. For safest local testing against a
# separate database, prefer `just local-run` (or `just local-reset-and-run` for a
# clean catalogue); those commands generate gitignored local-supabase.env.
# When these are set with SHELFPATH_DEBUG=true and SHELFPATH_STORAGE=supabase,
# visiting /login signs in without sending a magic-link email.
# SHELFPATH_LOCAL_AUTH_EMAIL=you@example.com
# SHELFPATH_LOCAL_AUTH_PASSWORD=local-password-for-local-supabase-only

# Optional for non-interactive Supabase CLI usage. Prefer `supabase login` locally.
# GitHub Actions uses SUPABASE_ACCESS_TOKEN and SUPABASE_DB_PASSWORD secrets.
# SUPABASE_ACCESS_TOKEN=
# SUPABASE_DB_PASSWORD=
